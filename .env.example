# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Databricks ──────────────────────────────────────────────────────────────
# CLI profile (used by deploy/upload_to_workspace.sh)
DATABRICKS_PROFILE=DEFAULT

# Workspace URL and a SQL warehouse the bridge will query
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<your-warehouse-id>

# PAT (starts with dapi…) or any OAuth Bearer token
DATABRICKS_TOKEN=<your-databricks-token>

# ── OSI semantic model location ─────────────────────────────────────────────
# Override these to point at your own catalog / schema / metric view.
# Most workspaces have a `main` catalog you can use; FEVM workspaces typically
# expose `<workspace>_catalog` instead. Pick one you have CREATE access to.
OSI_CATALOG=main
OSI_SCHEMA=osi_demo
OSI_METRIC_VIEW=orders_mv

# Where the exporter writes the OSI YAML and the bridge reads it from
OSI_MODEL_PATH=examples/model.osi.yaml

# ── Bridge server bind ──────────────────────────────────────────────────────
OSI_BRIDGE_HOST=0.0.0.0
OSI_BRIDGE_PORT=8000

# ── Gemini via Databricks Foundation Model APIs (OpenAI-compatible) ─────────
# No separate Google API key needed — the client reuses DATABRICKS_TOKEN.
GEMINI_MODEL=databricks-gemini-2-5-flash
# Or: databricks-gemini-2-5-pro

# ── Dremio adapter (optional) ───────────────────────────────────────────────
# Required only if you want the bridge to actually execute Dremio queries.
# Without these vars, the dispatcher still RENDERS the Dremio SQL so the demo
# can show the contract works on three engines.
# DREMIO_BASE_URL=https://<your-dremio-host>:9047
# DREMIO_TOKEN=<your-pat>

# ── Strategy Mosaic adapter (optional) ──────────────────────────────────────
# Same: optional, render-only without these.
# STRATEGY_BASE_URL=https://<your-strategy-host>
# STRATEGY_TOKEN=<your-token>
# Default Mosaic role granted by the access-request workflow.
# STRATEGY_PERMISSION_ROLE=consumer

# ── Portal store override (optional) ────────────────────────────────────────
# By default the portal uses --store file pointing at examples/models.
# PORTAL_STORE=sqlite
# OSI_BRIDGE_SQLITE=osi_bridge.db

# ── Producer journey / Git publishing (optional) ────────────────────────────
# Without these vars the /publish flow runs in dry-run only — it still
# generates OSI + ODCS and persists to the local store, but does not commit
# anything to GitHub.
# GITHUB_TOKEN=<pat-with-contents-write>
# GITHUB_CONTRACTS_REPO=<owner>/<repo>
# GITHUB_BRANCH=main
# GITHUB_AUTHOR_EMAIL=osi-bridge@databricks.com
# GITHUB_AUTHOR_NAME=OSI Bridge
# GITHUB_OSI_SUBDIR=examples/models
# GITHUB_ODCS_SUBDIR=examples/odcs
